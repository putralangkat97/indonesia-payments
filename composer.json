{
  "name": "anggit/indonesia-payments",
  "description": "Unified PHP SDK for Indonesian payment gateways (Midtrans, Xendit, etc.) with Laravel 13 integration.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "psr/http-client": "^1.0",
    "psr/http-message": "^1.0",
    "guzzlehttp/guzzle": "^7.8 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "Anggit\\IndonesiaPayments\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Anggit\\IndonesiaPayments\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/routing": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "carthage-software/mago": "^1.19"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Anggit\\IndonesiaPayments\\Laravel\\IndoPayServiceProvider"
      ],
      "aliases": {
        "Payment": "Anggit\\IndonesiaPayments\\Laravel\\Facades\\Payment"
      }
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "mago lint",
    "format": "mago format",
    "analyze": "mago analyze",
    "ci": [
      "@format",
      "@lint",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
